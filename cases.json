import json, random, copy

# ===================== CONFIG =====================
PROFESSIONS = [
    "medicine","dentistry","nursing",
    "vet","pharmacy","public_health","ams"
]

DEFAULT_TASK = {
    "medicine": "What is the diagnosis?",
    "dentistry": "Relevant oral manifestation?",
    "nursing": "Priority care?",
    "vet": "Analogous disease?",
    "pharmacy": "Drug of choice?",
    "public_health": "Risk factor?",
    "ams": "Confirmatory test?"
}

DEFAULT_IPA = {
    "medicine": "Clinical diagnosis",
    "dentistry": "Oral involvement",
    "nursing": "Monitoring",
    "vet": "Comparative disease",
    "pharmacy": "Medication",
    "public_health": "Risk factor",
    "ams": "Lab test"
}

DEFAULT_REF = {
    "source": "Standard Clinical Guideline",
    "year": 2024
}

BLOCKS = [
    "Endocrine","Cardiology","Nervous system","GI",
    "Hematology","Immunology","Microbiology",
    "Pharmacology","Musculoskeletal","Skin"
]

SYMPTOMS_POOL = [
    "fever","fatigue","pain","weight loss",
    "nausea","vomiting","weakness","rash",
    "cough","dyspnea","chest pain","headache"
]

DIAGNOSES_POOL = [
    "Infection","Inflammation","Autoimmune disease",
    "Malignancy","Metabolic disorder","Cardiac disease",
    "Neurological disorder"
]

# ===================== LOAD =====================
with open("cases.json","r",encoding="utf-8") as f:
    cases = json.load(f)

# ===================== VALIDATE + FIX =====================
def fix_case(case, idx):

    case = copy.deepcopy(case)

    # required fields
    case.setdefault("case_id", f"AUTO_{idx}")
    case.setdefault("block", random.choice(BLOCKS))
    case.setdefault("difficulty", random.choice(["easy","medium","hard"]))
    case.setdefault("mode", "scenario")

    case.setdefault("scenario", {"en":"Clinical case","th":"เคส"})
    case.setdefault("additional", {"en":"","th":""})
    case.setdefault("answer", random.choice(DIAGNOSES_POOL))
    case.setdefault("key_points", random.sample(SYMPTOMS_POOL,3))

    # FIX TASK
    if "task" not in case or not isinstance(case["task"],dict):
        case["task"] = copy.deepcopy(DEFAULT_TASK)

    for p in PROFESSIONS:
        case["task"].setdefault(p, DEFAULT_TASK[p])

    # FIX IPA
    if "interprofessional_answers" not in case:
        case["interprofessional_answers"] = {}

    for p in PROFESSIONS:
        case["interprofessional_answers"].setdefault(
            p,
            case["answer"] if p=="medicine" else DEFAULT_IPA[p]
        )

    # FIX REF
    case.setdefault("reference", DEFAULT_REF)

    return case

# ===================== GENERATE NEW CASE =====================
def generate_case(idx):

    diagnosis = random.choice(DIAGNOSES_POOL)
    symptoms = random.sample(SYMPTOMS_POOL,3)

    return {
        "case_id": f"GEN_{idx}",
        "block": random.choice(BLOCKS),
        "difficulty": random.choice(["easy","medium","hard"]),
        "mode": "scenario",
        "scenario": {
            "en": f"A patient presents with {', '.join(symptoms)}.",
            "th": f"ผู้ป่วยมี {', '.join(symptoms)}"
        },
        "additional": {"en":"","th":""},
        "answer": diagnosis,
        "key_points": symptoms,
        "task": DEFAULT_TASK,
        "interprofessional_answers": {
            "medicine": diagnosis,
            "dentistry": "Oral manifestation",
            "nursing": "Monitor patient",
            "vet": "Analog disease",
            "pharmacy": "Medication",
            "public_health": "Risk factor",
            "ams": "Lab test"
        },
        "reference": DEFAULT_REF
    }

# ===================== PROCESS =====================
clean_cases = []

for i,c in enumerate(cases):
    clean_cases.append(fix_case(c,i))

# เติมให้ครบ 100
while len(clean_cases) < 100:
    clean_cases.append(generate_case(len(clean_cases)))

# ===================== SAVE =====================
with open("cases_clean.json","w",encoding="utf-8") as f:
    json.dump(clean_cases,f,indent=2,ensure_ascii=False)

print(f"✅ Done: {len(clean_cases)} cases generated and cleaned")
